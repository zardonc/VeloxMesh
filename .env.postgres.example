GATEWAY_DATA_ADDR=:8080
GATEWAY_ADMIN_ADDR=:8081
GATEWAY_METRICS_ADDR=:9090
LOG_LEVEL=info
DEV_API_KEY=vx-dev

# Phase 2 Routing
ROUTING_STRATEGY=least-latency
# CONFIG_FILE=config.json

# Legacy Provider configuration (still supported)
DEFAULT_PROVIDER=openai-primary
OPENAI_PRIMARY_BASE_URL=https://api.openai.com/v1
OPENAI_PRIMARY_API_KEY=replace-with-provider-key
OPENAI_PRIMARY_MODELS=gpt-4o-mini
OPENAI_PRIMARY_DEFAULT_MODEL=gpt-4o-mini

# Plan 4 PostgreSQL + pgvector compose settings
POSTGRES_USER=veloxmesh
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_DB=veloxmesh
POSTGRES_PORT=5432

# Durable control state using PostgreSQL
CONTROL_STATE_BACKEND=postgres
CONTROL_STATE_DSN=postgres://veloxmesh:replace-with-local-password@localhost:5432/veloxmesh?sslmode=disable
CONTROL_STATE_MIGRATE_ON_STARTUP=true
CONTROL_STATE_LOCAL_SEED_ENABLED=true
CONTROL_STATE_ENCRYPTION_KEY=replace-with-32-byte-local-key!!

# Optional Redis Stack hot state
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_NAMESPACE=veloxmesh:local

# Plan 4 semantic cache vector path
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_VECTOR_STORE=pgvector
SEMANTIC_CACHE_VECTOR_DIMENSION=1536
PGVECTOR_INDEX_TYPE=hnsw
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
PGVECTOR_SEARCH_EF=40
