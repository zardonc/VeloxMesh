GATEWAY_DATA_ADDR=:8080
GATEWAY_ADMIN_ADDR=:8081
GATEWAY_METRICS_ADDR=:9090
LOG_LEVEL=info
DEV_API_KEY=vx-dev

# Phase 2 Routing
ROUTING_STRATEGY=least-latency
# CONFIG_FILE=config.json

# Optional component config files
# SCHEDULER_CONFIG_FILE=config.scheduler.example.json
# CACHE_CONFIG_FILE=config.cache.example.json

# Legacy Provider configuration (still supported)
DEFAULT_PROVIDER=openai-primary
OPENAI_PRIMARY_BASE_URL=https://api.openai.com/v1
OPENAI_PRIMARY_API_KEY=
OPENAI_PRIMARY_MODELS=gpt-4o-mini
OPENAI_PRIMARY_DEFAULT_MODEL=gpt-4o-mini

# Durable control state (SQLite-first)
# CONTROL_STATE_BACKEND=sqlite
# CONTROL_STATE_DSN=file:veloxmesh.db?cache=shared
# CONTROL_STATE_MIGRATE_ON_STARTUP=true
# CONTROL_STATE_LOCAL_SEED_ENABLED=true
# CONTROL_STATE_ENCRYPTION_KEY=32-byte-local-dev-key-change-me!

# Shared component host for local dev/test helpers; production sets concrete service addresses.
# DEV_SERVER_IP=

# Optional Redis Stack hot state
# REDIS_ENABLED=false
# REDIS_ADDR=<component-host>:6379
# REDIS_PORT=6379
# REDIS_NAMESPACE=veloxmesh:local

# Optional semantic cache / vector backend
# SEMANTIC_CACHE_ENABLED=false
# SEMANTIC_CACHE_PROVIDER=
# Empty vector store defaults to LanceDB when that build/runtime is available.
# Set qdrant explicitly to use service-backed vector search.
# SEMANTIC_CACHE_VECTOR_STORE=
# SEMANTIC_CACHE_VECTOR_DIMENSION=1536
# QDRANT_ADDR=<component-host>:6334
# QDRANT_PORT=6334

# Optional Scheduler queue foundation (disabled by default)
# SCHEDULER_ENABLED=false
# SCHEDULER_ENDPOINT=
# SCHEDULER_HEURISTIC_ENDPOINT=<heuristic-scheduler-host>:50051
# SCHEDULER_ONNX_ENDPOINT=<onnx-scheduler-host>:50051
# SCHEDULER_ONNX_ROLLOUT_PERCENT=0
# SCHEDULER_QUALITY_MAPE_ALERT_PERCENT=25
# SCHEDULER_ERROR_SPIKE_ALERT_RATE=0.05
# SCHEDULER_QUALITY_SAMPLE_WINDOW=100
# SCHEDULER_TIMEOUT=15ms
# SCHEDULER_STRICT=false
# SCHEDULER_BREAKER_FAILURE_THRESHOLD=3
# SCHEDULER_BREAKER_RECOVERY_TIMEOUT=1m
# SCHEDULER_SCORER_MAX_CONCURRENCY=4
# SCHEDULER_SCORER_SLOW_THRESHOLD=15ms
# auto/memory uses the default in-memory queue; redis is explicit and node-scoped.
# SCHEDULER_QUEUE_BACKEND=auto
# SCHEDULER_QUEUE_SOFT_LIMIT=0
# SCHEDULER_QUEUE_HARD_LIMIT=0
# SCHEDULER_QUEUE_POP_TIMEOUT=100ms
# SCHEDULER_EXECUTOR_CONCURRENCY=1
# SCHEDULER_DEFAULT_PRIORITY=normal
# SCHEDULER_MAX_PRIORITY=high
# SCHEDULER_HIGH_QUOTA_PER_MINUTE=0
# SCHEDULER_SCORE_UNCERTAINTY_PENALTY_K=0.2
# SCHEDULER_HEURISTIC_CONFIG_FILE=
# SCHEDULER_MODE=heuristic
# SCHEDULER_ONNX_ARTIFACT_DIR=
# SCHEDULER_FEEDBACK_ENABLED=false
# SCHEDULER_SEMANTIC_NEIGHBORS_ENABLED=false
# SCHEDULER_SEMANTIC_NEIGHBORS_EMBEDDING_MODEL=text-embedding-3-small
# SCHEDULER_SEMANTIC_NEIGHBORS_MIN_COUNT=20
# SCHEDULER_SEMANTIC_NEIGHBORS_INPUT_MAX_CHARS=16000
# SCHEDULER_SEMANTIC_NEIGHBORS_TASK_TIMEOUT=5ms
# SCHEDULER_SEMANTIC_NEIGHBORS_BATCH_TIMEOUT=15ms
# SCHEDULER_SLA_PROMOTION_ENABLED=false
# SCHEDULER_SLA_PROMOTION_CANDIDATE_WINDOW=32
