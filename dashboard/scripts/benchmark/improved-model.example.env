# Improved model identity. Obtain these values from the model owner.
IMPROVED_MODEL_PROVIDER_ID=improved-model-provider
IMPROVED_MODEL_BASE_URL=https://model-owner.example/v1
IMPROVED_MODEL_ID=improved-model-id
IMPROVED_MODEL_VERSION=replace_with_model_version
IMPROVED_MODEL_CONCURRENCY=1
IMPROVED_MODEL_TIMEOUT_SECONDS=30

# Runtime secrets. Replace locally and never commit populated values.
IMPROVED_MODEL_API_KEY=replace_with_improved_model_api_key
VELOXMESH_ADMIN_API_KEY=replace_with_gateway_admin_key
VELOXMESH_DATA_API_KEY=replace_with_gateway_data_plane_key
