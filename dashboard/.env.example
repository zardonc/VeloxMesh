# Dashboard runtime mode. Keep false in production.
DASHBOARD_DEMO_MODE=false
DASHBOARD_TEST_MODE=false

# Authentication security. Production cookies are Secure even if the explicit
# override is omitted. TestMode is required for local verification codes/outbox.
SESSION_TTL=8h
SESSION_COOKIE_SECURE=true
VERIFICATION_SEND_EMAIL_LIMIT=3
VERIFICATION_SEND_IP_LIMIT=20
VERIFICATION_VERIFY_EMAIL_LIMIT=10
VERIFICATION_VERIFY_IP_LIMIT=50
VERIFICATION_RATE_WINDOW=15m

# Production email verification. SMTP_PASSWORD itself must come from the
# process environment, or use a Docker/Kubernetes Secret file at this path.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD_FILE=
SMTP_FROM=
SMTP_TLS_MODE=starttls
SMTP_SERVER_NAME=
SMTP_TIMEOUT=10s

# VeloxMesh server-side integration. Never expose the admin key to Vite variables.
VELOXMESH_ADMIN_URL=http://127.0.0.1:8080
VELOXMESH_DATA_URL=http://127.0.0.1:8080
VELOXMESH_METRICS_URL=http://127.0.0.1:8080
VELOXMESH_ADMIN_API_KEY=replace-with-the-gateway-admin-key
VELOXMESH_DATA_API_KEY=replace-with-a-gateway-data-plane-key
VELOXMESH_API_TIMEOUT=10s

# Dashboard BFF and optional services.
BFF_ADDR=:8081
REDIS_ADDR=127.0.0.1:6379
QDRANT_URL=http://127.0.0.1:6333
ADMIN_STATE_PATH=tmp/admin-state.json
