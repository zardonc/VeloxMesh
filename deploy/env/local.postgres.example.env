GATEWAY_DATA_ADDR=:8080
GATEWAY_ADMIN_ADDR=:8081
GATEWAY_METRICS_ADDR=:9090
LOG_LEVEL=info

DEV_API_KEY=replace-with-local-dev-token

DEFAULT_PROVIDER=openai-primary
OPENAI_PRIMARY_BASE_URL=https://api.example.invalid/v1
OPENAI_PRIMARY_API_KEY=replace-with-provider-api-key
OPENAI_PRIMARY_MODELS=example-model
OPENAI_PRIMARY_DEFAULT_MODEL=example-model

POSTGRES_USER=replace-with-postgres-user
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=replace-with-postgres-database
POSTGRES_PORT=5432

CONTROL_STATE_BACKEND=postgres
CONTROL_STATE_DSN=postgres://replace-with-postgres-user:replace-with-postgres-password@localhost:5432/replace-with-postgres-database?sslmode=disable
CONTROL_STATE_MIGRATE_ON_STARTUP=true
CONTROL_STATE_LOCAL_SEED_ENABLED=true
CONTROL_STATE_ENCRYPTION_KEY=replace-with-32-byte-local-key!!

REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_NAMESPACE=veloxmesh:local

SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_VECTOR_STORE=pgvector
SEMANTIC_CACHE_VECTOR_DIMENSION=1536
PGVECTOR_INDEX_TYPE=hnsw
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
PGVECTOR_SEARCH_EF=40
