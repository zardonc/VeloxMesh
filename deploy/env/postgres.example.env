# Copy this file to deploy/env/postgres.env for the PostgreSQL/pgvector profile.
# Do not commit deploy/env/*.env.

# Local PostgreSQL admin user for the container.
POSTGRES_USER=replace-with-postgres-user

# Local PostgreSQL password for the container.
POSTGRES_PASSWORD=replace-with-postgres-password

# Local PostgreSQL database name.
POSTGRES_DB=replace-with-postgres-database

# Host port exposed by the PostgreSQL container.
POSTGRES_PORT=5432
