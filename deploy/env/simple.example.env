# Copy this file to deploy/env/simple.env for the no-Redis/no-Qdrant path.
# Do not commit deploy/env/*.env.

# Local bearer token accepted by the gateway.
DEV_API_KEY=replace-with-local-dev-token

# Provider key consumed by deploy/config/app.simple.example.json through auth.api_key_env.
OPENAI_PRIMARY_API_KEY=replace-with-provider-api-key

# Config files mounted into the gateway container. Copy these JSON examples
# to non-example names before putting real local-only values inside them.
VELOXMESH_APP_CONFIG=../config/app.simple.json
VELOXMESH_SCHEDULER_CONFIG=../config/scheduler.simple.json
VELOXMESH_CACHE_CONFIG=../config/cache.simple.json
VELOXMESH_PIPELINE_CONFIG=../config/pipeline.yaml
VELOXMESH_PROMETHEUS_CONFIG=../observability/prometheus.yml

# Grafana local login. Change before sharing the machine.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-local-grafana-password
